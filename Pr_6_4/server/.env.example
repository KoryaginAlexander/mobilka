# Copy this file to server/.env and fill in your Neon connection string.
# server/.env is gitignored.

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# Optional (otherwise defaults from Application.kt are used):
# JDBC_DATABASE_URL=jdbc:postgresql://...
# JWT_SECRET=at-least-32-characters-long-secret-key-here
# PORT=8080
# SYNC_INTERVAL_MS=86400000
# BOOTSTRAP_USER=admin
# BOOTSTRAP_PASSWORD=your-secure-password
